<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mode Camouflage"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choisissez un nom discret"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Spinner
        android:id="@+id/spinnerCamouflage"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="#161B22"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveCamouflage"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="ACTIVER LE CAMOUFLAGE"
        android:textColor="@color/white"
        android:layout_marginTop="24dp"
        app:backgroundTint="@color/green_primary"
        app:cornerRadius="8dp"
        app:layout_constraintTop_toBottomOf="@id/spinnerCamouflage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDisableCamouflage"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="DESACTIVER LE CAMOUFLAGE"
        android:textColor="@color/white"
        android:layout_marginTop="16dp"
        app:backgroundTint="#F85149"
        app:cornerRadius="8dp"
        app:layout_constraintTop_toBottomOf="@id/btnSaveCamouflage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>